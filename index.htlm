<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ton Nom - Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #ffffff; --text: #333; --accent: #007bff; --light: #f4f4f9; }
        body { font-family: 'Inter', sans-serif; line-height: 1.6; color: var(--text); margin: 0; padding: 0; background: var(--bg); scroll-behavior: smooth; }
        
        /* Menu de navigation */
        nav { position: fixed; top: 0; width: 100%; background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); border-bottom: 1px solid #eee; z-index: 1000; }
        nav ul { display: flex; justify-content: center; list-style: none; padding: 15px 0; margin: 0; }
        nav ul li { margin: 0 20px; }
        nav ul li a { text-decoration: none; color: var(--text); font-weight: 500; font-size: 0.9rem; transition: 0.3s; }
        nav ul li a:hover { color: var(--accent); }

        /* Sections */
        section { padding: 100px 20px; max-width: 800px; margin: 0 auto; border-bottom: 1px solid #f0f0f0; }
        .hero { text-align: center; padding: 150px 20px 100px; background: var(--light); }
        .hero img { width: 120px; border-radius: 50%; margin-bottom: 20px; border: 3px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        h1 { margin: 0; font-size: 2.5rem; }
        h2 { color: var(--accent); font-size: 1.5rem; margin-bottom: 30px; text-transform: uppercase; letter-spacing: 1px; }

        /* Style des listes */
        .item { margin-bottom: 25px; }
        .item h3 { margin: 0; font-size: 1.2rem; }
        .item p { margin: 5px 0; color: #666; }
        .tag { background: #eee; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem; }

        footer { text-align: center; padding: 40px; font-size: 0.8rem; color: #aaa; }
    </style>
</head>
<body>

    <nav>
        <ul>
            <li><a href="#about">À Propos</a></li>
            <li><a href="#posters">Posters</a></li>
            <li><a href="#publications">Publications</a></li>
            <li><a href="#associations">Associations</a></li>
        </ul>
    </nav>

    <header class="hero" id="about">
        <img src="https://github.com/ERedh.png" alt="Photo">
        <h1>[Ton Prénom] [Ton Nom]</h1>
        <p>Chercheur / Étudiant / Passionné par [Ton Domaine]</p>
    </header>

    <section id="posters">
        <h2>🖼 Présentations & Posters</h2>
        <div class="item">
            <h3>Titre de ton poster ou présentation</h3>
            <p>Conférence / Lieu - 2026</p>
            <a href="#" class="tag">Voir le PDF 📄</a>
        </div>
    </section>

    <section id="publications">
        <h2>📚 Publications</h2>
        <div class="item">
            <h3>Titre de l'article scientifique ou de la revue</h3>
            <p>Publié dans *Nom de la revue* - Janvier 2026</p>
            <a href="#" class="tag">Lien DOI 🔗</a>
        </div>
    </section>

    <section id="associations">
        <h2>🤝 Engagement Associatif</h2>
        <div class="item">
            <h3>Rôle dans l'association</h3>
            <p>Nom de l'association - Depuis 2024</p>
            <p>Description rapide de tes missions et réalisations.</p>
        </div>
    </section>

    <footer>
        &copy; 2026 - [Ton Nom] - Créé avec GitHub Pages
    </footer>

</body>
</html>
